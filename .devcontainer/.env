# Development Container Environment Variables

# Hugo settings
HUGO_ENV=development
HUGO_PARAMS_DESCRIPTION="Development version of the Hugo website"

# Node environment
NODE_ENV=development

# Enable verbose logging (optional)
# HUGO_LOG_LEVEL=debug

# Port configuration (if needed to override)
# HUGO_PORT=1313

# Enable future and draft content in development
HUGO_BUILD_DRAFTS=true
HUGO_BUILD_FUTURE=true

# Performance optimization
HUGO_ENABLE_FAST_RENDER=true
