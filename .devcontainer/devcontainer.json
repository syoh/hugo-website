{
  "name": "Ubuntu",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/hugo:1": {
      "extended": true,
      "version": "latest"
    }
  },
  "forwardPorts": [1313],
  // for Codespaces
  // "postCreateCommand": "hugo server -b https://${CODESPACE_NAME}-1313.${GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN} -p 1313 --appendPort=false --disableFastRender",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscodevim.vim"
      ]
    }
  }

}