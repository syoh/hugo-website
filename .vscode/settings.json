{
  "// Editor Settings": "Configuration for editing Hugo content and layouts",
  "editor.rulers": [80, 120],
  "editor.wordWrap": "on",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/node_modules": true,
    "**/public": true,
    "**/.hugo_build.lock": true,
    "**/resources/_gen": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/public": true,
    "**/resources/_gen": true,
    "themes/**": true
  },

  "// Markdown Settings": "Configuration for Markdown content",
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.wordWrap": "on",
    "editor.renderWhitespace": "none"
  },
  "markdownlint.config": {
    "MD013": {
      "line_length": 120,
      "code_blocks": false
    },
    "MD033": false
  },

  "// HTML/YAML Settings": "Configuration for templates and config files",
  "[yaml]": {
    "editor.formatOnSave": false,
    "editor.tabSize": 2
  },

  "// Hugo Settings": "Hugo template extension",
  "hugo.watch": true,
  "hugo.title": "Hugo",
  "hugo.port": "1313",

  "// Git Settings": "Git integration",
  "git.ignoreLimitWarning": true,
  "gitlens.showWelcomeOnInstall": false,

  "// Spelling": "Spell checker configuration",
  "cSpell.words": [
    "Igelfeld",
    "Hugo",
    "PaperMod",
    "frontmatter",
    "Michaillat",
    "postCreate"
  ],
  "cSpell.ignorePaths": [
    "themes/**",
    "node_modules/**",
    "public/**",
    "resources/**",
    ".git/**"
  ]
}
